<h3 xmlns=3D"http://www.w3.org/1999/xhtml" id=3D"sites-page-title-header" s=
tyle=3D"" align=3D"left">
<span id=3D"sites-page-title" dir=3D"ltr" tabindex=3D"-1" style=3D"outline:=
 none">Intel Galileo - Building Linux Image</span>
</h3>
<span class=3D"announcementsPostTimestamp" id=3D"afterPageTitleHideDuringEd=
it">

     =20
   =20
 =20
  posted <span xmlns=3D"http://www.w3.org/1999/xhtml" dir=3D"ltr">Oct 24, 2=
013, 5:17 PM</span> by Sergey Kiselev

                 =20
                      &nbsp;
                      <span id=3D"sites-announcement-updated-time" class=3D=
"updatedTime">
                        [
 =20
 =20
 =20
